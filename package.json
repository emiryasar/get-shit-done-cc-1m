{
  "name": "get-shit-done-cc-1m",
  "version": "1.22.4-1m.2",
  "description": "GSD fork optimized for 1M context windows. Deep codebase awareness, parallel research (6-8 agents), expanded thresholds, Opus max effort, worktree isolation. Based on get-shit-done-cc by TÂCHES.",
  "bin": {
    "get-shit-done-cc-1m": "bin/install.js"
  },
  "files": [
    "bin",
    "commands",
    "get-shit-done",
    "agents",
    "hooks/dist",
    "scripts"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "meta-prompting",
    "context-engineering",
    "spec-driven-development",
    "gemini",
    "gemini-cli",
    "codex",
    "codex-cli"
  ],
  "author": "TÂCHES",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emiryasar/get-shit-done-cc-1m.git"
  },
  "homepage": "https://github.com/emiryasar/get-shit-done-cc-1m",
  "bugs": {
    "url": "https://github.com/emiryasar/get-shit-done-cc-1m/issues"
  },
  "gsd_1m_config": {
    "base_version": "1.22.4",
    "context_tier": "1m",
    "default_profile": "deep",
    "default_effort": "max",
    "parallel_researchers": 8,
    "max_tasks_per_plan": 8,
    "max_files_per_plan": 35,
    "analysis_paralysis_threshold": 15
  },
  "engines": {
    "node": ">=16.7.0"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "esbuild": "^0.24.0"
  },
  "scripts": {
    "build:hooks": "node scripts/build-hooks.js",
    "prepublishOnly": "npm run build:hooks",
    "test": "node scripts/run-tests.cjs",
    "test:coverage": "c8 --check-coverage --lines 70 --reporter text --include 'get-shit-done/bin/lib/*.cjs' --exclude 'tests/**' --all node scripts/run-tests.cjs"
  }
}
